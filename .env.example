# =============================================================================
# NHL Web Predictor — Переменные окружения
# =============================================================================
# Скопируйте этот файл в .env и заполните значения.
# На Replit используйте вкладку "Secrets" (не коммитьте .env в репозиторий!).
# =============================================================================

# -----------------------------------------------------------------------------
# ОБЯЗАТЕЛЬНЫЕ
# -----------------------------------------------------------------------------

# Секрет для Flask сессий (любая случайная строка, мин. 32 символа)
SESSION_SECRET=your_random_secret_string_here

# URL базы данных PostgreSQL
# Формат: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/nhlpredictor

# -----------------------------------------------------------------------------
# ДАННЫЕ О МАТЧАХ (выберите один или несколько источников)
# -----------------------------------------------------------------------------

# FlashLive Sports API (через RapidAPI) — основной источник live-данных NHL
# Получить: https://rapidapi.com/flashlive-sports/api/flashlive-sports
RAPIDAPI_KEY=your_rapidapi_key_here

# API-Sports — альтернативный источник (NHL, KHL и другие лиги)
# Получить: https://www.api-football.com/ или https://api-sports.io/
API_SPORTS_KEY=your_api_sports_key_here

# -----------------------------------------------------------------------------
# КОТИРОВКИ БУКМЕКЕРОВ (выберите один или несколько)
# -----------------------------------------------------------------------------

# The Odds API — котировки от множества букмекеров
# Получить: https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here

# AllBestBets API — альтернативный источник котировок
# Получить: https://allbestbets.ru/ (если доступно)
ALLBESTBETS_API_TOKEN=your_allbestbets_token_here
ALLBESTBETS_FILTER_ID=your_filter_id_here

# -----------------------------------------------------------------------------
# TELEGRAM УВЕДОМЛЕНИЯ (опционально)
# -----------------------------------------------------------------------------

# Токен Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID чата для отправки уведомлений (получить у @userinfobot)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# -----------------------------------------------------------------------------
# SUPABASE (опционально — альтернатива PostgreSQL)
# -----------------------------------------------------------------------------

# URL проекта Supabase
SUPABASE_URL=https://your-project.supabase.co

# Anon (public) ключ Supabase
SUPABASE_ANON_KEY=your_supabase_anon_key_here
