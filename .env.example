# =============================================================================
# Pattern Interruption — Environment Variables
# Скопируй в .env и заполни значения:
#   cp .env.example .env
#   nano .env
# =============================================================================

# --- Обязательные ---
SESSION_SECRET=your_random_secret_key_here_32_chars_min
DATABASE_URL=postgresql://pattern_user:your_db_password@localhost/pattern_interruption

# --- Telegram уведомления ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- FlashLive / RapidAPI (для live odds) ---
RAPIDAPI_KEY=
FLASH_API_PROXY_URL=

# --- API-Sports (football, basketball odds) ---
APISPORTS_KEY=

# --- AllBestBets (fallback для value bets) ---
ALLBESTBETS_API_TOKEN=

# --- Supabase (опционально, если используешь Supabase Auth) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
